# ============================================
# Folder2Podcast 环境变量配置模板
# ============================================
# 复制此文件为 .env 并根据实际情况修改

# 服务器端口
PORT=3100

# 服务器基础 URL（用于生成 RSS feed 中的链接）
# 开发环境示例: http://localhost:3100
# 生产环境示例: https://podcast.example.com
BASE_URL=http://localhost:3100

# 音频文件根目录（绝对路径）
# 开发环境示例: /Users/your-name/Desktop/audio_books
# 生产环境示例: /podcasts
AUDIO_DIR=./audio

# 标题显示策略
# clean: 清理后的标题（去除序号、特殊字符）
# full: 完整文件名（不含扩展名）
TITLE_FORMAT=full

# 管理 API 密钥（可选，用于保护管理接口）
# 留空则不启用认证
# 生成方法: openssl rand -hex 32
API_KEY=

# Node 环境（development/production）
NODE_ENV=development
