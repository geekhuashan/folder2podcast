# ============================================
# Folder2Podcast Next.js 环境变量配置
# ============================================

# 服务器端口
PORT=3100

# 服务器基础 URL（不包含端口号）
# 系统会自动拼接 BASE_URL:PORT 生成完整的访问地址
#
# 示例：
# - 开发环境: http://localhost
# - 局域网: http://192.168.1.100
# - 生产环境: http://your-domain.com 或 https://your-domain.com
BASE_URL=http://localhost

# 数据库文件路径（可选）
# 默认: ./data/podcasts.db
# DATABASE_URL=./data/podcasts.db

# ============================================
# 认证配置（三种模式）
# ============================================
#
# 模式一：单用户模式（推荐个人使用）
# - 设置 ADMIN_USERNAME 和 ADMIN_PASSWORD
# - 容器启动时自动创建管理员用户
# - 自动禁止注册（仅允许管理员使用）
#
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# 模式二：固定多用户模式（推荐团队使用）
# - 设置 USERS（格式：user1:pass1,user2:pass2）
# - 容器启动时批量创建固定用户
# - 自动禁止注册（仅允许指定用户使用）
# - 优先级高于 ADMIN_USERNAME
#
# USERS=admin:pass123,alice:pass456,bob:pass789

# 模式三：开放注册模式（公开服务）
# - 不设置 ADMIN_USERNAME 和 USERS
# - 自动允许用户通过注册页面自行注册
# - 注释掉或删除上述两个配置即可启用此模式


