# ============================================
# Folder2Podcast 环境变量配置模板
# ============================================
# 复制此文件为 .env 并根据实际情况修改

# 后端服务器端口
PORT=3100

# 前端开发服务器端口（仅开发模式使用，生产环境下前端由后端服务）
VITE_PORT=3200

# 服务器主机名/IP地址
# 开发环境示例: localhost 或 192.168.1.100
# 生产环境示例: podcast.example.com 或服务器的公网IP
# 注意：BASE_URL 会自动根据 HOST 和 PORT 生成为 http://HOST:PORT
HOST=localhost

# 音频文件根目录（绝对路径）
# 开发环境示例: /Users/your-name/Desktop/audio_books
# 生产环境示例: /podcasts
AUDIO_DIR=./audio

# 标题显示策略
# clean: 清理后的标题（去除序号、特殊字符）
# full: 完整文件名（不含扩展名）
TITLE_FORMAT=full

# 管理 API 密钥（可选，用于保护管理接口）
# 留空则不启用认证
# 生成方法: openssl rand -hex 32
API_KEY=

# Node 环境（development/production）
NODE_ENV=development
