# ============================================
# Folder2Podcast Next.js 环境变量配置
# ============================================

# 服务器端口
PORT=3100

# 服务器基础 URL（不包含端口号）
# 系统会自动拼接 BASE_URL:PORT 生成完整的访问地址
#
# 示例：
# - 开发环境: http://localhost
# - 局域网: http://192.168.1.100
# - 生产环境: http://your-domain.com 或 https://your-domain.com
BASE_URL=http://localhost

# 数据库文件路径（可选）
# 默认: ./data/podcasts.db
# DATABASE_URL=./data/podcasts.db

# ============================================
# 认证配置
# ============================================

# 是否允许用户注册（可选）
# 设置为 false 可以关闭注册功能，只允许管理员账号使用
# 默认: true（允许注册）
# ENABLE_REGISTRATION=false

# 管理员账号配置（可选）
# 设置后可以使用管理员账号直接登录，无需在数据库中创建用户
# 建议在关闭注册后使用管理员账号
# Access Key 会基于用户名和密码自动生成，修改密码后旧的 Access Key 将自动失效
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

