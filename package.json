{
  "name": "folder2podcast",
  "version": "1.0.0",
  "description": "Convert audio folders to podcast feeds with HTTP server",
  "main": "dist/index.js",
  "bin": {
    "folder2podcast": "dist/index.js"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "build:web": "cd web && npm run build",
    "build:all": "npm run build && npm run build:web",
    "start": "node dist/index.js",
    "dev:backend": "ts-node src/index.ts",
    "dev:frontend": "cd web && npm run dev",
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "tag": "node scripts/tag-version.js",
    "generate-changelog": "ts-node scripts/generate-changelog.ts",
    "docker:build": "docker build -t folder2podcast:dev .",
    "docker:test": "docker run -d --name folder2podcast-test -p 3100:3100 -v $HOME/Desktop/audio_books:/podcasts folder2podcast:dev",
    "docker:stop": "docker stop folder2podcast-test && docker rm folder2podcast-test",
    "docker:clean": "npm run docker:stop && docker rmi folder2podcast:dev",
    "docker:mac": "docker run -d --name folder2podcast-mac -p 3100:3100 -v $HOME/Desktop/audio_books:/podcasts -e PUID=$(id -u) -e PGID=$(id -g) -e PORT=3100 -e BASE_URL=http://localhost:3100 folder2podcast:dev",
    "docker:mac:stop": "docker stop folder2podcast-mac && docker rm folder2podcast-mac"
  },
  "keywords": [
    "podcast",
    "rss",
    "audio",
    "server"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/multipart": "^7.7.3",
    "@fastify/static": "^6.12.0",
    "chokidar": "^3.5.3",
    "dotenv": "^17.2.3",
    "fastify": "^4.25.2",
    "feed": "^4.2.2",
    "fs-extra": "^11.2.0",
    "path": "^0.12.7",
    "pinyin": "^3.0.0-alpha.5",
    "podcast": "^2.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.5",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
